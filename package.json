{
  "name": "vscode-time-traveller",
  "displayName": "Git Time Traveller",
  "description": "Pick any commit, branch, or stash as the gutter diff baseline, and ask @historian why a line changed.",
  "version": "1.0.0",
  "publisher": "darrenjaworski",
  "author": "Darren Jaworski <darrenjaworski@gmail.com>",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/darrenjaworski/vscode-time-traveller.git"
  },
  "bugs": {
    "url": "https://github.com/darrenjaworski/vscode-time-traveller/issues"
  },
  "homepage": "https://github.com/darrenjaworski/vscode-time-traveller#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "SCM Providers",
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "git",
    "blame",
    "history",
    "diff",
    "baseline",
    "chat",
    "copilot",
    "llm",
    "ai",
    "pull request",
    "commit",
    "source control"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "timeTraveller.pickBaseline",
        "title": "Time Traveller: Pick Diff Baseline…",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.clearBaseline",
        "title": "Time Traveller: Clear Diff Baseline",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.showCurrentBaseline",
        "title": "Time Traveller: Show Current Baseline",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.pickBaselineForFile",
        "title": "Time Traveller: Pick Diff Baseline for This File…",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.clearBaselineForFile",
        "title": "Time Traveller: Clear Per-File Baseline",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.stepBaselineBackward",
        "title": "Time Traveller: Step Baseline Backward (older)",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.stepBaselineForward",
        "title": "Time Traveller: Step Baseline Forward (newer)",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.openDiffWithBaseline",
        "title": "Time Traveller: Open Diff with Baseline",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.history.setAsGlobalBaseline",
        "title": "Set as workspace baseline",
        "category": "Time Traveller",
        "icon": "$(globe)"
      },
      {
        "command": "timeTraveller.history.askHistorianAboutFile",
        "title": "Ask @historian about this file",
        "category": "Time Traveller",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "timeTraveller.askHistorianForHunk",
        "title": "Ask @historian why this hunk changed",
        "category": "Time Traveller",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "timeTraveller.history.openDiffPrev",
        "title": "Compare with previous revision",
        "category": "Time Traveller",
        "icon": "$(diff)"
      },
      {
        "command": "timeTraveller.history.openOnRemote",
        "title": "Open commit on remote",
        "category": "Time Traveller",
        "icon": "$(link-external)"
      },
      {
        "command": "timeTraveller.history.clearFileBaseline",
        "title": "Compare working tree to HEAD",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.history.refresh",
        "title": "Refresh",
        "category": "Time Traveller",
        "icon": "$(refresh)"
      },
      {
        "command": "timeTraveller.history.setBaseline",
        "title": "Set as diff baseline",
        "category": "Time Traveller",
        "icon": "$(target)"
      },
      {
        "command": "timeTraveller.history.openAtRevision",
        "title": "Open file at this revision",
        "category": "Time Traveller",
        "icon": "$(file)"
      },
      {
        "command": "timeTraveller.history.openDiff",
        "title": "Compare with working tree",
        "category": "Time Traveller",
        "icon": "$(git-compare)"
      },
      {
        "command": "timeTraveller.history.askHistorian",
        "title": "Ask @historian about this commit",
        "category": "Time Traveller",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "timeTraveller.history.storyOfCommit",
        "title": "Tell the story of this commit",
        "category": "Time Traveller",
        "icon": "$(book)"
      },
      {
        "command": "timeTraveller.history.copySha",
        "title": "Copy commit SHA",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.history.copySubject",
        "title": "Copy commit subject",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.history.loadMore",
        "title": "Load more history",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.history.setTextFilter",
        "title": "Filter by subject/body…",
        "category": "Time Traveller",
        "icon": "$(filter)"
      },
      {
        "command": "timeTraveller.history.toggleHideMerges",
        "title": "Toggle hide merge commits",
        "category": "Time Traveller",
        "icon": "$(git-merge)"
      },
      {
        "command": "timeTraveller.history.setGrouping",
        "title": "Group history by…",
        "category": "Time Traveller",
        "icon": "$(list-tree)"
      },
      {
        "command": "timeTraveller.history.clearFilters",
        "title": "Clear filters",
        "category": "Time Traveller",
        "icon": "$(clear-all)"
      },
      {
        "command": "timeTraveller.signInToGitHub",
        "title": "Sign in to GitHub for @historian PR context",
        "category": "Time Traveller"
      },
      {
        "command": "timeTraveller.walkthroughs.askHistorian",
        "title": "Open @historian in the chat panel",
        "category": "Time Traveller"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "timeTraveller.fileHistory",
          "name": "File History",
          "contextualTitle": "Time Traveller"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "timeTraveller.history.setTextFilter",
          "when": "view == timeTraveller.fileHistory",
          "group": "navigation@1"
        },
        {
          "command": "timeTraveller.history.setGrouping",
          "when": "view == timeTraveller.fileHistory",
          "group": "navigation@2"
        },
        {
          "command": "timeTraveller.history.clearFilters",
          "when": "view == timeTraveller.fileHistory && timeTraveller.history.hasFilters",
          "group": "navigation@3"
        },
        {
          "command": "timeTraveller.history.askHistorianAboutFile",
          "when": "view == timeTraveller.fileHistory",
          "group": "navigation@4"
        },
        {
          "command": "timeTraveller.history.refresh",
          "when": "view == timeTraveller.fileHistory",
          "group": "navigation@5"
        },
        {
          "command": "timeTraveller.history.toggleHideMerges",
          "when": "view == timeTraveller.fileHistory",
          "group": "1_filters@1"
        }
      ],
      "view/item/context": [
        {
          "command": "timeTraveller.history.openDiff",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "inline@1"
        },
        {
          "command": "timeTraveller.history.openDiffPrev",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "inline@2"
        },
        {
          "command": "timeTraveller.history.askHistorian",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "inline@3"
        },
        {
          "command": "timeTraveller.history.setBaseline",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "1_baseline@1"
        },
        {
          "command": "timeTraveller.history.setAsGlobalBaseline",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "1_baseline@2"
        },
        {
          "command": "timeTraveller.history.openAtRevision",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "2_open@1"
        },
        {
          "command": "timeTraveller.history.openDiff",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "2_open@2"
        },
        {
          "command": "timeTraveller.history.openDiffPrev",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "2_open@3"
        },
        {
          "command": "timeTraveller.history.openOnRemote",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "2_open@4"
        },
        {
          "command": "timeTraveller.history.askHistorian",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "3_chat@1"
        },
        {
          "command": "timeTraveller.history.storyOfCommit",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "3_chat@2"
        },
        {
          "command": "timeTraveller.history.copySha",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "9_copy@1"
        },
        {
          "command": "timeTraveller.history.copySubject",
          "when": "view == timeTraveller.fileHistory && viewItem == timeTraveller.history.entry",
          "group": "9_copy@2"
        }
      ],
      "commandPalette": [
        {
          "command": "timeTraveller.history.refresh",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.setBaseline",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.openAtRevision",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.openDiff",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.askHistorian",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.copySha",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.copySubject",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.setAsGlobalBaseline",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.openDiffPrev",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.openOnRemote",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.clearFileBaseline",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.askHistorianAboutFile",
          "when": "false"
        },
        {
          "command": "timeTraveller.askHistorianForHunk",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.loadMore",
          "when": "false"
        },
        {
          "command": "timeTraveller.history.storyOfCommit",
          "when": "false"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "timeTraveller.historian",
        "name": "historian",
        "fullName": "Historian",
        "description": "Narrate the git history of your code — who, when, and most importantly *why*.",
        "isSticky": true,
        "commands": [
          {
            "name": "why",
            "description": "Explain why the selected lines look the way they do"
          },
          {
            "name": "story",
            "description": "Narrative timeline of the active file"
          },
          {
            "name": "since",
            "description": "Explain what changed in this file since a ref (e.g. `/since v1.2.0`)"
          },
          {
            "name": "author",
            "description": "Summarize this file's history by a specific author (e.g. `/author Alice`)"
          }
        ]
      }
    ],
    "chatVariables": [
      {
        "name": "timeTraveller.baseline",
        "description": "Current diff baseline ref"
      },
      {
        "name": "timeTraveller.history",
        "description": "Recent commits on the active file"
      },
      {
        "name": "timeTraveller.commit",
        "description": "Currently selected History panel commit"
      }
    ],
    "languageModelTools": [
      {
        "name": "timeTraveller_getCommitDetails",
        "displayName": "Get commit details",
        "modelDescription": "Read a commit's metadata (subject, body, author, date) and optionally its files-changed list. Use when you need to understand what a specific commit did.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sha": {
              "type": "string",
              "description": "Full or short SHA"
            },
            "includeFiles": {
              "type": "boolean",
              "description": "Include the files-changed list (numstat)"
            }
          },
          "required": [
            "sha"
          ]
        }
      },
      {
        "name": "timeTraveller_searchCommits",
        "displayName": "Search commits",
        "modelDescription": "Find commits matching a pattern (in subject or body). Useful for discovering commits by keyword or feature name.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string",
              "description": "Regex pattern to search subject and body"
            },
            "limit": {
              "type": "number",
              "description": "Maximum number of results (default 10)"
            }
          },
          "required": [
            "pattern"
          ]
        }
      },
      {
        "name": "timeTraveller_getCommitDiff",
        "displayName": "Get commit diff",
        "modelDescription": "Read the full diff for a commit, optionally filtered to a single file. Use when you need to see what changed in a specific commit.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sha": {
              "type": "string",
              "description": "Full or short SHA"
            },
            "relPath": {
              "type": "string",
              "description": "Relative path to filter diff to a single file (optional)"
            },
            "maxChars": {
              "type": "number",
              "description": "Maximum characters to return (default 5000)"
            }
          },
          "required": [
            "sha"
          ]
        }
      },
      {
        "name": "timeTraveller_getBlame",
        "displayName": "Get blame",
        "modelDescription": "Show who last touched each line in a range (line number, author, date, commit subject). Use to understand the recent history of specific lines.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "relPath": {
              "type": "string",
              "description": "Relative file path"
            },
            "startLine": {
              "type": "number",
              "description": "Starting line number (1-based, inclusive)"
            },
            "endLine": {
              "type": "number",
              "description": "Ending line number (1-based, inclusive)"
            }
          },
          "required": [
            "relPath",
            "startLine",
            "endLine"
          ]
        }
      },
      {
        "name": "timeTraveller_findPRsForCommit",
        "displayName": "Find PRs for commit",
        "modelDescription": "Look up pull requests or merge requests associated with a commit (GitHub, GitLab, Bitbucket supported). Use to understand which PR introduced a change.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sha": {
              "type": "string",
              "description": "Full or short SHA"
            }
          },
          "required": [
            "sha"
          ]
        }
      },
      {
        "name": "timeTraveller_listFileHistory",
        "displayName": "List file history",
        "modelDescription": "Show recent commits that touched a file, with optional filtering by author or since a given ref. Use to understand the evolution of a file.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "relPath": {
              "type": "string",
              "description": "Relative file path"
            },
            "since": {
              "type": "string",
              "description": "Show commits since this ref (optional, e.g., v1.0.0 or HEAD~10)"
            },
            "author": {
              "type": "string",
              "description": "Filter by author name pattern (optional, regex)"
            },
            "limit": {
              "type": "number",
              "description": "Maximum number of commits to return (default 20)"
            }
          },
          "required": [
            "relPath"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Git Time Traveller",
      "properties": {
        "timeTraveller.defaultBaseline": {
          "type": "string",
          "default": "HEAD",
          "description": "Default git ref to diff against when no baseline is picked. Set to something like `origin/main` to always see gutter diffs against your integration branch."
        },
        "timeTraveller.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show an 'Ask @historian why this changed' CodeLens above each hunk in the gutter diff."
        },
        "timeTraveller.hover.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the commit that last touched a line as a hover tooltip, but only on lines that are changed relative to the current baseline."
        },
        "timeTraveller.chat.maxBlameEvidenceTokens": {
          "type": "number",
          "default": 4000,
          "description": "Soft cap on characters of patch/diff evidence sent per @historian query (commit-focused lookups use this; per-file /why diffs scale down proportionally). Lower it when hitting model context limits."
        },
        "timeTraveller.chat.toolCalling": {
          "type": "boolean",
          "default": true,
          "description": "Allow the model to invoke @historian tools to pull evidence on demand."
        },
        "timeTraveller.chat.maxToolRounds": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum tool-call rounds per query."
        },
        "timeTraveller.pr.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Fetch pull-request context for commits cited by @historian. Supports GitHub, GitHub Enterprise, GitLab, and Bitbucket. Requires appropriate authentication (session or token)."
        },
        "timeTraveller.gitlabToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Personal access token for GitLab MR lookups. Used when the GitLab Workflow extension is not installed. Treat as a secret."
        },
        "timeTraveller.bitbucketAppPassword": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bitbucket Cloud app password for PR lookups. Treat as a secret."
        },
        "timeTraveller.gheToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Personal access token for GitHub Enterprise Server PR lookups. Treat as a secret."
        },
        "timeTraveller.enterprise.hosts": {
          "type": "object",
          "default": {},
          "markdownDescription": "Map of self-hosted hostnames to provider types. Example: `{\"git.acme.corp\": \"github-enterprise\"}`. Routes PR/MR lookups to the correct provider for on-prem instances."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "timeTraveller.gettingStarted",
        "title": "Get started with Git Time Traveller",
        "description": "Narrate git history with @historian, pick any commit as your diff baseline, and browse file history inline.",
        "steps": [
          {
            "id": "askHistorian",
            "title": "Ask @historian why",
            "description": "Open the chat panel and ask why the code is the way it is. Grounded in blame, log, patch excerpts, and (on GitHub) PR context.\n[Open chat with /story](command:timeTraveller.walkthroughs.askHistorian)",
            "media": {
              "markdown": "walkthroughs/ask-historian.md"
            },
            "completionEvents": [
              "onCommand:timeTraveller.walkthroughs.askHistorian"
            ]
          },
          {
            "id": "pickBaseline",
            "title": "Pick a diff baseline",
            "description": "Compare the gutter against any branch, tag, stash, or commit — not just HEAD.\n[Pick a baseline…](command:timeTraveller.pickBaseline)",
            "media": {
              "markdown": "walkthroughs/pick-baseline.md"
            },
            "completionEvents": [
              "onCommand:timeTraveller.pickBaseline"
            ]
          },
          {
            "id": "fileHistory",
            "title": "Browse file history",
            "description": "The File History panel shows `git log --follow` for the active file. Click any row to set it as the per-file baseline; right-click for story-of-a-commit and more.\n[Reveal the panel](command:workbench.view.scm)",
            "media": {
              "markdown": "walkthroughs/file-history.md"
            },
            "completionEvents": [
              "onView:timeTraveller.fileHistory"
            ]
          },
          {
            "id": "githubSignIn",
            "title": "(Optional) Sign in to GitHub for PR context",
            "description": "On GitHub-backed repos, @historian can fold PR titles and bodies into its prompt. Silent — never prompts during a chat.\n[Sign in to GitHub](command:timeTraveller.signInToGitHub)",
            "media": {
              "markdown": "walkthroughs/github-signin.md"
            },
            "completionEvents": [
              "onCommand:timeTraveller.signInToGitHub"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run clean && npm run compile",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "typecheck": "tsc --noEmit -p ./ && tsc --noEmit -p ./tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package",
    "kitchen-sink": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run compile && npm run package"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5",
    "vscode-uri": "^3.1.0"
  }
}
